# ── Required ──────────────────────────────────────────────────────────────────
BRAVE_API_KEY=your-brave-api-key-here

# ── LLM Provider: OpenAI (default for planning + demo extraction) ────────────
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=                                # leave blank for official OpenAI

# ── LLM Provider: Groq (optional alternate extractor) ────────────────────────
# Groq remains supported via an OpenAI-compatible API, but it is no longer the
# default demo extractor path because free-tier rate limits made live runs less stable.
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1   # default; override if needed

# ── Provider routing ──────────────────────────────────────────────────────────
# Which LLM provider each pipeline stage uses.
PLANNER_PROVIDER=openai
EXTRACTOR_PROVIDER=openai

# ── App config ────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Pipeline tuning (optional) ────────────────────────────────────────────────
# MAX_RESULTS_PER_ANGLE=5     # Brave results to fetch per search angle
# MAX_CONCURRENT_SCRAPES=5    # Parallel page fetch limit
# SCRAPE_TIMEOUT=15           # Per-page timeout in seconds
# CACHE_TTL_HOURS=24          # How long to reuse cached pages
# GAP_FILL_MAX_ENTITIES=3     # Max entities targeted by gap-fill
# RERANK_ENABLED=true         # Cross-encoder reranking before extraction
# RERANK_TOP_K=10             # Pages to send to extraction after reranking

# ── Ablation toggles (optional) ──────────────────────────────────────────────
# CELL_VERIFIER_ENABLED=true
# SOURCE_DIVERSITY_WEIGHT=0.08
